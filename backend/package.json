{
  "name": "@dofuscompagnon/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/apply-sqlite-migrations.mjs && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:apply": "node scripts/apply-sqlite-migrations.mjs",
    "import:runes": "tsx src/database/import-runes.ts",
    "import:dofusbook:equipments": "tsx src/database/import-dofusbook-equipments.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@prisma/client": "6.10.1",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "prisma": "6.10.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
